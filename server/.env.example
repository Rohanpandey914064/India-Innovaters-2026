# ============================================================
# CitySpark - Backend / Server Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to `.env`
#   2. Fill in your actual values below
#   3. NEVER commit `.env` to GitHub!
# ============================================================

# MongoDB Connection String
# Get yours at: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cityspark?retryWrites=true&w=majority

# Server Port
PORT=5000

# JWT Secret - Use a long, random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_long_random_jwt_secret_here

# JWT Expiry
JWT_EXPIRES_IN=7d

# Gemini AI API Key (server-side)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
